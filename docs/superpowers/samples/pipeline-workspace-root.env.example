# 结构说明（可提交）：真实密钥副本见同目录 pipeline-workspace-root.env（已 .gitignore，由本机仓库根 .env 同步）
# 使用：materialize 后复制到 {WORKSPACE_ROOT}\.env，或手动对齐键名与路径约定（UTF-8）
#
# —— 路径与工作区 ——
# 勿写 PIPELINE_WORKSPACE_PATH。进程环境变量 VLA_WORKSPACE_ROOT = materialize --workspace 所选绝对路径。
# QA_RULE_FILE 使用 rules/ 下相对工作区根的路径。
#
# —— webhook HTTP 探活（bootstrap probe GET <WEBHOOK_PROBE_BASE>/health；完整签字须在 webhook 已监听后执行）；端口按本机 webhook 监听改 ——
WEBHOOK_PROBE_BASE=http://127.0.0.1:8787
#
# —— 文件夹路由（真源优先 §7）——
# 生产优先：在工作区根 .env 配置 FEISHU_FOLDER_ROUTE_KEYS 与各 FEISHU_FOLDER_<KEY>_*（与 onboard env_contract 五键同质）。
# FOLDER_ROUTES_FILE 指向的 JSON 仅 legacy / 未配置 ROUTE_KEYS 时的回退；不必与「双写 JSON」运维模型绑定。
#
FEISHU_FOLDER_ROUTE_KEYS=MAIN
FEISHU_FOLDER_MAIN_NAME=main-demo-route
FEISHU_FOLDER_MAIN_TOKEN=your_folder_token_here
FEISHU_FOLDER_MAIN_QA_RULE_FILE=rules/sample_qa.md
FEISHU_FOLDER_MAIN_DATASET_ID=your_dataset_id_here
FEISHU_FOLDER_MAIN_DIFY_TARGET_KEY=DEFAULT
#
# —— Dify 静态实例组（由 dify_target_key 选择）——
DIFY_TARGET_DEFAULT_API_BASE=https://api.dify.ai/v1
DIFY_TARGET_DEFAULT_API_KEY=your_api_key_here
DIFY_TARGET_DEFAULT_HTTP_VERIFY=true
DIFY_TARGET_DEFAULT_TIMEOUT_SECONDS=60
#
# —— 遗留 JSON 路由文件路径（可选；仅未设置 FEISHU_FOLDER_ROUTE_KEYS 时使用）——
# FOLDER_ROUTES_FILE=C:\\path\\to\\clone\\webhook\\config\\folder_routes.json
#
REDIS_URL=redis://127.0.0.1:6379/0
CURSOR_RUN_TIMEOUT_SECONDS=7200
