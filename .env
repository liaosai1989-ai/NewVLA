# 本地调试用根 .env（已在 .gitignore，勿将真实密钥提交到 Git）
# 飞书 / Dify 下述占位需换成开放平台与 Dify 控制台真实值后联调
# 说明：ENV-OLD-TO-NEW.md、.env.example

# ---------------------------------------------------------------------------
# 飞书应用（onboard 建夹、lark-cli config init；全仓库一组）
# ---------------------------------------------------------------------------
FEISHU_API_BASE=https://open.feishu.cn
FEISHU_APP_ID=cli_a940252864b89bcb
FEISHU_APP_SECRET=Wl6WkGgPJjH5Crxy7rVX4aD6ANYcRcXx
# 入轨必填：为分享委托人加云空间文件夹协作者；填该用户 open_id（ou_…）
FEISHU_ONBOARD_FOLDER_DELEGATE_OPEN_ID=ou_9878f48f6d306c4c6e3a27bf9466d257
# 可选，默认 openid、full_access
#FEISHU_ONBOARD_FOLDER_DELEGATE_MEMBER_TYPE=openid
#FEISHU_ONBOARD_FOLDER_DELEGATE_PERM=full_access

# ---------------------------------------------------------------------------
# Dify 静态组（<KEY>=DEBUG 示例；onboard 会校验四键非空；调试可指向本机/沙箱）
# ---------------------------------------------------------------------------
DIFY_TARGET_TDS_API_BASE=http://localhost/v1
DIFY_TARGET_TDS_API_KEY=dataset-GxKYDMgBd0JA4xkDEVpuRPa8
DIFY_TARGET_TDS_HTTP_VERIFY=false
DIFY_TARGET_TDS_TIMEOUT_SECONDS=60

# ---------------------------------------------------------------------------
# 按 route 业务映射（与 feishu-onboard 两阶段写盘一致；联调前可改 TOKEN/DATASET）
# 仅示例：与 webhook/config/folder_routes.example.json 中 fld_team_a 对齐便于一体调试
# ---------------------------------------------------------------------------
FEISHU_FOLDER_ROUTE_KEYS=TEAM_A,TDS
FEISHU_FOLDER_TEAM_A_NAME=DebugTeamA
FEISHU_FOLDER_TEAM_A_TOKEN=fld_team_a
FEISHU_FOLDER_TEAM_A_DIFY_TARGET_KEY=DEBUG
FEISHU_FOLDER_TEAM_A_DATASET_ID=dataset_team_a
FEISHU_FOLDER_TEAM_A_QA_RULE_FILE=prompts/rules/qa/folders/folder_rule_template.mdc

# ---------------------------------------------------------------------------
# 抓取 / lark（feishu_fetch：固定命令名 lark-cli + PATH，与入轨一致；不读 LARK_CLI_COMMAND）
# ---------------------------------------------------------------------------
FEISHU_REQUEST_TIMEOUT_SECONDS=60

# ---------------------------------------------------------------------------
# Webhook 执行器（webhook/src/webhook_cursor_executor/settings.py）
# ---------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6381/0
VLA_QUEUE_NAME=vla:default
FEISHU_WEBHOOK_PATH=/webhook/feishu
# 本地可留空走宽松校验；上生产请配置飞书应用后台事件与解密
FEISHU_ENCRYPT_KEY=lgPgxGdBrEeDUTUTEH1qPbwri5JE3WLC
FEISHU_VERIFICATION_TOKEN=EWmvPmjO6Dj4zo2UGpeT7g56RbSkNqFg

EVENT_SEEN_TTL_SECONDS=86400
DOC_SNAPSHOT_TTL_SECONDS=86400
DOC_RUNLOCK_TTL_SECONDS=10800
DOC_RERUN_TTL_SECONDS=86400
RUN_CONTEXT_TTL_SECONDS=259200
RUN_RESULT_TTL_SECONDS=259200
CURSOR_RUN_TIMEOUT_SECONDS=7200

# 相对仓库根；若工作目录非仓根，请改为绝对路径
FOLDER_ROUTES_FILE=webhook/config/folder_routes.example.json
CURSOR_CLI_MODEL=composer-2-fast
# 省略 CURSOR_CLI_CONFIG_PATH 时使用默认：%USERPROFILE%\.cursor\cli-config.json

# ---------------------------------------------------------------------------
# 若未 editable 安装 feishu-onboard，可在系统环境变量设置 FEISHU_ONBOARD_REPO_ROOT=本仓绝对路径
# ---------------------------------------------------------------------------
FEISHU_FOLDER_TDS_NAME=TDS
FEISHU_FOLDER_TDS_TOKEN=FnYMfeiZclvH8wdwp3vcESc1nog
FEISHU_FOLDER_TDS_DIFY_TARGET_KEY=TDS
FEISHU_FOLDER_TDS_DATASET_ID=86bfd429-aad4-457c-b3f7-9e2b7199e284
FEISHU_FOLDER_TDS_QA_RULE_FILE=prompts/rules/qa/folders/folder_rule_template.mdc
