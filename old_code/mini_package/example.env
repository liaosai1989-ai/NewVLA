# Minimal env example for the Feishu app-folder mini package

FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=secret_xxx

# Used after the folder is created
FEISHU_SUBSCRIBE_FOLDER_TOKEN=fld_xxx

# Used by the grant-user helper
FEISHU_USER_OPEN_ID=ou_xxx
FEISHU_USER_ACCESS_TOKEN=

# Optional overrides
FEISHU_DRIVE_CREATE_PARENT_TOKEN=
FEISHU_FOLDER_GRANT_PERM=full_access
FEISHU_FOLDER_GRANT_USE_USER_TOKEN=0
FEISHU_FOLDER_LINK_SHARE_ENTITY=tenant_editable
FEISHU_FOLDER_EXTERNAL_ACCESS=closed
