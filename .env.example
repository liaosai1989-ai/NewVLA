# 仓库根 .env 合同占位模板（可提交版本；复制为 .env 后填入真实值）
# 详见证件：ENV-OLD-TO-NEW.md 与 docs/superpowers/specs/2026-04-26-root-env-and-dify-target-contract-design.md
#
# materialize 复制到「执行工作区根」后使用；工作区绝对路径仅通过 bootstrap --workspace（或 interactive-setup）传递，勿在此增加 PIPELINE_WORKSPACE_PATH。
# 生产起 webhook/RQ 前须在进程环境中设置 VLA_WORKSPACE_ROOT=<与 --workspace 相同绝对路径>（勿指望仅从即将加载的工作区 .env 自举该变量）。
#
# --- 飞书单应用（onboard / lark-cli 初始化）---
# FEISHU_APP_ID=cli_xxxxxxxx
# FEISHU_APP_SECRET=

# --- Dify 静态实例组（<KEY> 为自定义大写标识，如 DEFAULT、PROD_A）---
# 整组四键须同时存在且非空；可有多组 DIFY_TARGET_*。
# DIFY_TARGET_DEFAULT_API_BASE=https://api.example.com/v1
# DIFY_TARGET_DEFAULT_API_KEY=app-xxxxxxxx
# DIFY_TARGET_DEFAULT_HTTP_VERIFY=true
# DIFY_TARGET_DEFAULT_TIMEOUT_SECONDS=60

# --- 按 route 的业务映射（与 onboard env_contract 五键同质；由 feishu-onboard 写回；示例 MAIN）---
# FEISHU_FOLDER_ROUTE_KEYS=MAIN
# FEISHU_FOLDER_MAIN_NAME=main-folder-display-name
# FEISHU_FOLDER_MAIN_TOKEN=xnliuoxxfolderxxxx
# FEISHU_FOLDER_MAIN_DIFY_TARGET_KEY=DEFAULT
# FEISHU_FOLDER_MAIN_DATASET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# FEISHU_FOLDER_MAIN_QA_RULE_FILE=rules/qa/folders/main.mdc

# --- Webhook 执行器（见 webhook/src/webhook_cursor_executor/settings.py；按需取消注释）---
# REDIS_URL=redis://127.0.0.1:6379/0
# VLA_QUEUE_NAME=vla:default
# FEISHU_WEBHOOK_PATH=/webhook/feishu
# FEISHU_ENCRYPT_KEY=
# FEISHU_VERIFICATION_TOKEN=
# 无 folder_token 事件（如 drive.file.edit_v1）列目录匹配父夹时必配（可与 onboard 同应用）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# EVENT_SEEN_TTL_SECONDS=86400
# legacy：仅当未配置 FEISHU_FOLDER_ROUTE_KEYS 时回退路有 JSON（见 webhook load_routing_config）
# FOLDER_ROUTES_FILE=webhook/config/folder_routes.example.json
# CURSOR_RUN_TIMEOUT_SECONDS=7200
# CURSOR_CLI_MODEL=composer-2-fast
# 勿设 CURSOR_CLI_COMMAND：webhook 固定 PATH 上 `cursor`（同 onboard 对 lark-cli 的约定）

# --- 抓取链路（lark-cli 已初始化后；勿写 LARK_CLI_COMMAND，feishu_fetch 会报错且只调 PATH 上 lark-cli）---
# FEISHU_REQUEST_TIMEOUT_SECONDS=60
# FEISHU_APP_ID=cli_xxxxxxxx

# --- 非 editable 安装 feishu-onboard 时（环境变量，通常不进 .env）---
# set FEISHU_ONBOARD_REPO_ROOT=C:\path\to\repo\root
